Vid köp av ett spel är priset 50,99 kr. Då antalet spel passerar gränserna 5, 10 och 15 ges rabatt med 5%, 10% respektive 15% på hela köpet. 
Tillverka ett program som frågar efter önskat antal spel och som beräknar priset för inköpet.




Console.Write("Antal spel att köpa ? ");
int spel=int.Parse(Console.ReadLine());

const double pris = 50.99d;
double rabattpris;
double spelpris = spel * pris;

if (spel < 5) 
{
    rabattpris = spelpris;
}
else if (spel < 10)
{
        rabattpris = spelpris*0.95;
}
else if (spel < 15)
{
        rabattpris = spelpris * 0.90;
}
else
{
    rabattpris = spelpris * 0.85;
}
Console.WriteLine($"Kostnaden för {spel} spel är {rabattpris:F2} kronor");

